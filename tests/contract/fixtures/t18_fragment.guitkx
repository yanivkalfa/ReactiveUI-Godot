component NamedFragment(xs: Array = []) {
  return (
    <VBoxContainer>
      <Fragment>
        <Label text="a" />
        <Label text="b" />
      </Fragment>
      @for (i in 3) {
        return (
          <Fragment key={ str(i) }>
            <Label text={ str(i) } />
          </Fragment>
        )
      }
    </VBoxContainer>
  )
}
