@class_name DemoSlicing

component DemoSlicing() {
	var sliced = useState(RUIConfig.time_slicing)
	var rev = useState(0)
	var toggle = func():
		RUIConfig.time_slicing = not sliced[0]
		sliced[1].call(not sliced[0])
	return (
		<DemoBox title="Time-slicing — chunk big renders across frames">
			<HBox style={ {"separation": 8} }>
				<Button text={ "Time-slicing: %s" % ("ON" if sliced[0] else "OFF") } onClick={ toggle } />
				<Button text="Re-render 25 rows" onClick={ func(): rev[1].call(rev[0] + 1) } />
			</HBox>
			<Label text="With slicing ON, big updates spread over frames (commit stays atomic)." style={ {"font_color": Color(0.7, 0.7, 0.7)} } />
			<Scroll style={ {"min_height": 200} }>
				<VBox style={ {"separation": 2} }>
					@for (i in 25) {
						<Label key={ str(i) } text={ "row %d  (rev %d)" % [i, rev[0]] } />
					}
				</VBox>
			</Scroll>
		</DemoBox>
	)
}
