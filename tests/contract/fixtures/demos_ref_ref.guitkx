import { DemoBox } from "~/examples/demos/demo_box"

export DemoRef() -> RUIVNode {
  var input_ref = useRef(null)
  var focus = func():
    if input_ref["current"] != null:
      input_ref["current"].grab_focus()
  return (
    <DemoBox title="useRef — imperative node access">
      <LineEdit
        placeholder_text="focus me with the button →"
        ref={ input_ref }
        style={ {"min_width": 280} } />
      <Button text="Focus the field" onPressed={ focus } />
    </DemoBox>
  )
}
