@class_name DemoContextConsumer

component DemoContextConsumer {
  var accent = useContext("accent")
  return (
    <PanelContainer style={ {"bg_color": accent, "corner_radius_all": 6, "content_margin_all": 12} }>
      <Label text="I'm tinted by context" style={ {"font_color": Color.WHITE} } />
    </PanelContainer>
  )
}
