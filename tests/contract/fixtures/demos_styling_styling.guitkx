@class_name DemoStyling

component DemoStyling {
  return (
    <DemoBox title="Styling — StyleBoxFlat + theme channels">
      <Panel style={ DemoStylingStyle.PANEL }>
        <VBox style={ {"separation": 4} }>
          <Label
            text="Styled panel"
            style={ {"font_size": 22, "font_color": Color(0.6, 0.8, 1.0)} } />
          <Label
            text="bg + corner radius + border, all from one StyleBoxFlat (styles live in styling.style.gd)"
            style={ {"font_color": Color(0.7, 0.7, 0.7)} } />
        </VBox>
      </Panel>
      <HBox style={ {"separation": 10} }>
        <Panel style={ DemoStylingStyle.SQUARE_RED } />
        <Panel style={ DemoStylingStyle.SQUARE_GREEN } />
        <Panel style={ DemoStylingStyle.SQUARE_BLUE } />
      </HBox>
      <Label text="Theme channels reach any item:" style={ {"font_color": Color(0.7, 0.7, 0.7)} } />
      <Label text="outlined text" style={ DemoStylingStyle.OUTLINED } />
    </DemoBox>
  )
}
