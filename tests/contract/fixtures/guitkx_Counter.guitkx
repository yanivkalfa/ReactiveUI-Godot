@class_name GuitkxCounter

## A first .guitkx example: hooks + an event handler + a conditional. The reactive_ui editor
## plugin compiles this to a sibling Counter.gd (class_name GuitkxCounter) on save / project scan.
component GuitkxCounter(start: int = 0) {
  var s = useState(start)
  var count = s[0]
  var set_count = s[1]
  return (
    <VBoxContainer style={ {"separation": 8} }>
      <Label text={ "Count: %d" % count } />
      <Button text="+1" onPressed={ func(): set_count.call(count + 1) } />
      @if (count > 5) {
        return (
          <Label text="High five!" />
        )
      }
    </VBoxContainer>
  )
}
