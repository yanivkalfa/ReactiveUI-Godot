# Normalize line endings for text files (binaries auto-detected, left alone).
* text=auto eol=lf

# Shape the archive the Godot Asset Library serves (provider zip of the download commit)
# and any `git archive` output. This is an ALLOWLIST: everything is export-ignored by
# default, then only the runtime addon is added back. New top-level files (agent tooling,
# stray notes, project configs) can never silently leak into an install again — the failure
# mode of the old denylist, which shipped .claude/, discordpost, and export_presets.cfg.
#
# The runtime addon carries its own LICENSE/README/CHANGELOG, so nothing at the repo root
# needs to ship.
/** export-ignore
/addons !export-ignore
/addons/reactive_ui !export-ignore
/addons/reactive_ui/** !export-ignore

# The editor addon ships through its OWN Asset Library listing (Custom provider + release
# zip — a Download Commit can't carry it), so it must stay out of the runtime archive.
# Dev-only material inside the runtime addon must not reach end users either.
/addons/reactive_ui_editor export-ignore
/addons/reactive_ui_editor/** export-ignore
/addons/reactive_ui/dev export-ignore
/addons/reactive_ui/dev/** export-ignore
