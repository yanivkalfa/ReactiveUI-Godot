# Shape the archive the Godot Asset Library serves (provider zip of the download commit) and
# any `git archive` output: an install should contain the addon, its license, and the README —
# not the demo gallery, the test rig, the IDE toolchain, or the docs site.
/examples export-ignore
/tests export-ignore
/ide-extensions export-ignore
/ReactiveUIGodotDocs~ export-ignore
/plans export-ignore
/research export-ignore
/.github export-ignore
/.gitattributes export-ignore
/.gitignore export-ignore
/addons/reactive_ui_editor export-ignore
/addons/reactive_ui/dev export-ignore
/godotLogo.png export-ignore
/godotLogo100.png export-ignore
/CLAUDE.md export-ignore
# Never let an addon install clobber the user's own project files.
/project.godot export-ignore
/icon.png export-ignore
/.asset-template.json.hb export-ignore
