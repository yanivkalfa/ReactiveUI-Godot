# Godot 4 editor cache / import data — regenerated by the editor, machine-specific.
.godot/

# Generated GUITKX output: each Foo.guitkx compiles to a sibling Foo.gd (the Godot editor plugin
# and CI's `--editor --quit` step regenerate them — see addons/reactive_ui/plugin.gd). Commit the
# .guitkx source, not the build artifact. The hand-written scripts under examples/ are re-included.
examples/**/*.gd
!examples/app.gd
!examples/demos/signals/signals_store.gd
!examples/demos/styling/styling.style.gd
!examples/demos/context_handle/accent_context.gd
!examples/demos/doom/doom_types.gd
!examples/demos/doom/doom_textures.gd
!examples/demos/doom/doom_maps.gd
!examples/demos/doom/raycast.gd
!examples/demos/doom/game_logic.gd
!examples/demos/doom/doom_game_screen_logic.gd
!examples/demos/doom/doom_bootstrap.gd
# …and their transient companions: Godot per-script .uid + the compiler's diagnostics sidecars.
examples/**/*.gd.uid
*.guitkx.diags.json

# Bundled ClassDB dump (copied from lsp-server/classdb by bundle-server.js at package time) +
# Godot import sidecars for non-runtime extension assets (icons/logos scanned under res://).
ide-extensions/vscode/classdb/
*.png.import

# Exported builds
/build/
*.tmp

# Test scratch directories (tests/*_test.gd create + clean these up on success; an interrupted or
# crashed run can leave them behind untracked -- never commit the debris).
tests/__*_tmp/

# OS noise
.DS_Store
Thumbs.db

# Publishing secrets (extension marketplace tokens) — never commit
publisher-secrets.json
addons/reactive_ui_analyzer/
