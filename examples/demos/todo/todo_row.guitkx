@class_name DemoTodoRow

component DemoTodoRow(item, onRemove) {
  return (
    <HBoxContainer style={ {"separation": 8} }>
      <Label text={ "•  " + str(item["text"]) } style={ {"size_flags_horizontal": Control.SIZE_EXPAND_FILL} } />
      <Button text=" ✕ " onPressed={ func(): onRemove.call(item["id"]) } />
    </HBoxContainer>
  )
}
