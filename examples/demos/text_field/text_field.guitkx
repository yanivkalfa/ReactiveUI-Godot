@class_name DemoTextField

component DemoTextField() {
	var s = use_state("")
	return (
		<DemoBox title="Text Field — controlled input">
			<LineEdit text={ s[0] } placeholder_text="Type something…" on_text_changed={ func(t): s[1].call(t) } style={ {"min_width": 280} } />
			<Label text={ "You typed: \"%s\"  (%d chars)" % [s[0], s[0].length()] } />
		</DemoBox>
	)
}
