@class_name DemoBailout

component DemoBailout() {
	var n = use_state(0)
	return (
		<DemoBox title="Bailout — unchanged children skip re-render">
			<Label text={ "Parent state: %d" % n[0] } />
			<Button text="Re-render parent" on_pressed={ func(): n[1].call(n[0] + 1) } />
			<Label text="The child's props never change → its render count stays flat:" style={ {"font_color": Color(0.7, 0.7, 0.7)} } />
			<DemoBailoutChild label="static" />
		</DemoBox>
	)
}
