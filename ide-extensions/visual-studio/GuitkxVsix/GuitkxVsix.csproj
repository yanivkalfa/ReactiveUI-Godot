<?xml version="1.0" encoding="utf-8"?>
<!-- VS2022 VSIX (legacy project format — requires VS2022 + the "Visual Studio extension development"
     workload / Microsoft.VSSDK.BuildTools to build). Builds a MEF component VSIX whose ILanguageClient
     launches the shared Node language server; the TextMate grammar under Syntaxes\ is registered by
     guitkx.pkgdef. Before packaging, copy the built server into .\server (see ide-extensions/README). -->
<Project ToolsVersion="Current" DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>{7F2A9C41-3B6E-4E2A-9D1C-2E8F5A6B0C77}</ProjectGuid>
    <OutputType>Library</OutputType>
    <RootNamespace>GuitkxVsix</RootNamespace>
    <AssemblyName>GuitkxVsix</AssemblyName>
    <TargetFrameworkVersion>v4.7.2</TargetFrameworkVersion>
    <!-- GuitkxPackage (added for the Phase 1 options page) carries real VSPackage registration
         attributes ([PackageRegistration]/[ProvideOptionPage]/[ProvideAutoLoad]), so this now DOES
         need CreatePkgDef to reflect them into a generated GuitkxVsix.pkgdef, flipped from false.
         (Verified: with it false, the package/options-page attributes silently produced no pkgdef at
         all, i.e. compiled but never registered with VS.) The static guitkx.pkgdef (TextMate grammar
         registration) stays separate; see the guitkx.pkgdef Content item below for the real
         pre-existing bug this uncovered (it was never actually bundled at all, regardless of this
         flag). -->
    <GeneratePkgDefFile>true</GeneratePkgDefFile>
    <IncludeAssemblyInVSIXContainer>true</IncludeAssemblyInVSIXContainer>
    <IncludeDebugSymbolsInVSIXContainer>false</IncludeDebugSymbolsInVSIXContainer>
    <CopyBuildOutputToOutputDirectory>true</CopyBuildOutputToOutputDirectory>
    <CreateVsixContainer>true</CreateVsixContainer>
    <DeployExtension>true</DeployExtension>
  </PropertyGroup>
  <!-- Per-configuration output paths. Without an OutputPath, Microsoft.Common.targets aborts with
       "BaseOutputPath/OutputPath property is not set" and never produces GuitkxVsix.dll (so
       CreateVsixContainer then fails with VSSDK1025). [audit] -->
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <ItemGroup>
    <!-- MenuCommandService (base of OleMenuCommandService, used by the restart command) lives in
         the classic .NET Framework GAC assembly System.Design, not a NuGet package. -->
    <Reference Include="System.Design" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="GuitkxContentDefinition.cs" />
    <Compile Include="GuitkxLanguageClient.cs" />
    <Compile Include="GuitkxPackage.cs" />
    <Compile Include="GuitkxOptionsPage.cs" />
    <Compile Include="GuitkxSettings.cs" />
    <Compile Include="GuitkxEditorDefaults.cs" />
    <Compile Include="GuitkxBraceCompletion.cs" />
    <Compile Include="GuitkxSmartIndent.cs" />
    <Compile Include="GuitkxFormatOnSave.cs" />
  </ItemGroup>
  <ItemGroup>
    <!-- Compiles to Menus.ctmenu, matching GuitkxPackage's [ProvideMenuResource("Menus.ctmenu", 1)]. -->
    <VSCTCompile Include="GuitkxCommands.vsct">
      <ResourceName>Menus.ctmenu</ResourceName>
    </VSCTCompile>
  </ItemGroup>
  <ItemGroup>
    <None Include="source.extension.vsixmanifest">
      <SubType>Designer</SubType>
    </None>
    <!-- MUST be a Content item, not None: VsSDK.targets' GetVsixSourceItems target only honors
         IncludeInVSIX on @(Content) (Microsoft.VsSDK.targets ~l.612-621); a None item's
         IncludeInVSIX metadata is silently ignored. Confirmed by building this file's pre-Phase-1
         state (git worktree at commit aedef25) and inspecting the produced .vsix with `unzip -l`:
         guitkx.pkgdef was NEVER actually bundled, at any point in this project's history, meaning
         the TextMate grammar registration this file exists for has likely never reached a real
         installed VS2022 instance (no .guitkx syntax highlighting). This was a real, pre-existing,
         silent bug, not something introduced by the Phase 1 GeneratePkgDefFile change (confirmed
         unrelated by testing both true and false). -->
    <Content Include="guitkx.pkgdef">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <IncludeInVSIX>true</IncludeInVSIX>
    </Content>
    <Content Include="Syntaxes\guitkx.tmLanguage.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <IncludeInVSIX>true</IncludeInVSIX>
      <VSIXSubPath>Syntaxes</VSIXSubPath>
    </Content>
    <Content Include="language-configuration.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <IncludeInVSIX>true</IncludeInVSIX>
    </Content>
    <!-- Extension icon (manifest <Icon>, ~90px) + marketplace preview (manifest <PreviewImage>). -->
    <Content Include="icon.png">
      <IncludeInVSIX>true</IncludeInVSIX>
    </Content>
    <Content Include="preview.png">
      <IncludeInVSIX>true</IncludeInVSIX>
    </Content>
    <!-- The bundled Node language server (populate .\server before packaging). -->
    <Content Include="server\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <IncludeInVSIX>true</IncludeInVSIX>
      <VSIXSubPath>server\%(RecursiveDir)</VSIXSubPath>
    </Content>
  </ItemGroup>
  <ItemGroup>
    <!-- Pinned to the real, exact versions published for the VS 2022 17.7 GA family (2023-08-10).
         The previous pins (LanguageServer.Client 17.7.41, VSSDK.BuildTools 17.7.2189) do not exist on
         NuGet. MSBuild's PackageReference floats a bare version number to the nearest available
         version at or above the requested one, so restore silently resolved LanguageServer.Client to
         17.8.36 (a different minor line than SDK/BuildTools) with NU1603/NU1605 warnings, including a
         detected Microsoft.VisualStudio.Telemetry downgrade, instead of failing loudly. Verified via
         `dotnet restore` plus the NuGet v3 flat-container API before pinning these. -->
    <PackageReference Include="Microsoft.VisualStudio.LanguageServer.Client" Version="17.7.20" />
    <PackageReference Include="Microsoft.VisualStudio.SDK" Version="17.7.37357" ExcludeAssets="runtime" />
    <PackageReference Include="Microsoft.VSSDK.BuildTools" Version="17.7.2196" PrivateAssets="all" />
  </ItemGroup>
  <!-- REQUIRED: Microsoft.CSharp.targets pulls in Microsoft.Common.targets (which defines the `Build`
       target) AND imports obj\*.nuget.g.targets (which loads the Microsoft.VSSDK.BuildTools package
       targets). Without this line BOTH `Build` and `CreateVsixContainer` are undefined -> MSB4057. -->
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
  <!-- Defines CreateVsixContainer / VSCTCompile / GeneratePkgDef. Microsoft.VSSDK.BuildTools' auto-
       imported props point $(VSToolsPath) at the package's OWN tools folder, so this resolves to the
       NuGet copy of VsSDK.targets even on a CI runner with no VS-installed VSSDK workload. -->
  <Import Project="$(VSToolsPath)\VSSDK\Microsoft.VsSDK.targets" Condition="Exists('$(VSToolsPath)\VSSDK\Microsoft.VsSDK.targets')" />
</Project>
